# NodeLoom Self-Hosted Configuration
# Copy this file to .env and fill in the required values
#
# SECURITY: Generate all secrets before first startup!
# Quick generate all secrets:
#   echo "APP_ENCRYPTION_KEY=$(openssl rand -base64 32)"
#   echo "JWT_SECRET=$(openssl rand -base64 64)"
#   echo "APP_ADMIN_API_KEY=$(openssl rand -base64 32)"
#   echo "POSTGRES_PASSWORD=$(openssl rand -base64 24)"
#   echo "REDIS_PASSWORD=$(openssl rand -base64 24)"

# =============================================================================
# REQUIRED: Security Secrets
# =============================================================================
# WARNING: The application will NOT start without valid security secrets!
# Do NOT use default/example values - generate unique keys for your deployment.

# Encryption key for credentials storage (AES-256-GCM)
# Generate with: openssl rand -base64 32
# CRITICAL: If you change this key, all stored credentials become unreadable!
APP_ENCRYPTION_KEY=

# JWT signing secret (minimum 256 bits / 32 characters)
# Generate with: openssl rand -base64 64
JWT_SECRET=

# Admin API key for backoffice communication
# Generate with: openssl rand -base64 32
APP_ADMIN_API_KEY=

# =============================================================================
# REQUIRED: License
# =============================================================================

# License key (obtain from NodeLoom)
NODELOOM_LICENSE_KEY=NL-XXXXX-XXXXX-XXXXX-XXXXX

# =============================================================================
# REQUIRED: Initial Admin User (first startup only)
# =============================================================================

ADMIN_EMAIL=admin@yourcompany.com
ADMIN_PASSWORD=YourSecurePassword123
ADMIN_FIRST_NAME=Admin
ADMIN_LAST_NAME=User

# =============================================================================
# REQUIRED: Database Credentials
# =============================================================================

# Database password (generate a strong random password)
POSTGRES_PASSWORD=

# Redis password (generate a strong random password)
REDIS_PASSWORD=

# =============================================================================
# VERSION
# =============================================================================

# NodeLoom version to deploy (default: latest)
NODELOOM_VERSION=latest

# =============================================================================
# APPLICATION URLs
# =============================================================================
# These MUST be set correctly for email links, OAuth callbacks, and webhooks.

# Application URLs — all on the same origin via nginx reverse proxy.
# Change to your actual domain in production (e.g., https://nodeloom.yourdomain.com)
APP_BASE_URL=http://localhost
APP_FRONTEND_URL=http://localhost
PUBLIC_API_URL=http://localhost
APP_CORS_ALLOWED_ORIGINS=http://localhost

# Cookie security — set to true when using HTTPS, false for HTTP
APP_COOKIE_SECURE=false

# =============================================================================
# PROXY / NETWORK
# =============================================================================

# Set to NATIVE when behind a reverse proxy (nginx, ALB, Cloudflare, etc.)
# This ensures X-Forwarded-For, X-Forwarded-Proto headers are trusted
# Options: NONE (direct), NATIVE (behind trusted proxy)
FORWARD_HEADERS_STRATEGY=NATIVE

# =============================================================================
# DATABASE SETTINGS
# =============================================================================

POSTGRES_DB=nodeloom
POSTGRES_USER=nodeloom
POSTGRES_PORT=5432

# Connection pool tuning (defaults are suitable for most deployments)
# HIKARI_MAX_POOL_SIZE=20
# HIKARI_MIN_IDLE=5

# =============================================================================
# REDIS SETTINGS
# =============================================================================

REDIS_PORT=6379

# =============================================================================
# APPLICATION PORTS
# =============================================================================

BACKEND_PORT=8080
FRONTEND_PORT=3000

# =============================================================================
# LICENSE SETTINGS (Advanced)
# =============================================================================
# The license validation URL and signature verification are hardcoded in the
# self-hosted backend image and cannot be overridden.

# Machine identifier for license binding (auto-generated if not set)
# MACHINE_ID=

# =============================================================================
# AI PROVIDERS (Optional - add as needed)
# =============================================================================

# OpenAI
OPENAI_API_KEY=

# Anthropic (Claude)
ANTHROPIC_API_KEY=

# Google AI (Gemini)
GOOGLE_AI_API_KEY=

# Azure OpenAI
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=

# =============================================================================
# OAUTH PROVIDERS (Optional)
# =============================================================================
# Configure OAuth providers for one-click credential connections.
# Alternatively, configure via Settings > OAuth Providers in the UI.

# Google (Gmail, Sheets, Drive, Calendar, Docs)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Slack
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# Microsoft (Outlook, Teams, OneDrive, SharePoint, Excel 365)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Salesforce
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=

# HubSpot
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=

# Shopify
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
# SHOPIFY_SHOP_DOMAIN=

# Zoom
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=

# Asana
ASANA_CLIENT_ID=
ASANA_CLIENT_SECRET=

# Linear
LINEAR_CLIENT_ID=
LINEAR_CLIENT_SECRET=

# Jira
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=

# Notion
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=

# =============================================================================
# CAPTCHA (Optional - Cloudflare Turnstile)
# =============================================================================
# Protects registration from bots. Disabled by default.

CAPTCHA_ENABLED=false
# CAPTCHA_SITE_KEY=
# CAPTCHA_SECRET_KEY=
# CAPTCHA_VERIFY_URL=https://challenges.cloudflare.com/turnstile/v0/siteverify

# =============================================================================
# OPTIONAL: Agent Discovery
# =============================================================================
# Agent discovery sources (AWS Bedrock, Azure AI, GCP Vertex, GitHub, Anthropic)
# are configured through the UI at Agent Inventory → Integrations.
# No environment variables needed — credentials are stored encrypted in the database.
#
# To override the Anthropic API base URL (e.g., for proxy or testing):
# APP_ANTHROPIC_API_BASE=https://api.anthropic.com

# =============================================================================
# OPTIONAL: SSRF Protection
# =============================================================================
# SSRF protection validates outbound URLs to block private/internal networks.
# Enabled by default. Only disable for local development/testing.
# APP_SSRF_PROTECTION_ENABLED=true

# =============================================================================
# OPTIONAL: SIEM Export
# =============================================================================
# SIEM export (Splunk, Datadog, Elasticsearch, Webhook) is configured
# through the UI at Audit → SIEM tab. No environment variables needed.

# =============================================================================
# STRIPE BILLING (Optional)
# =============================================================================

STRIPE_ENABLED=false
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# =============================================================================
# SANDBOX EXECUTION (Optional)
# =============================================================================
# Enables sandboxed code execution in Docker containers.
# Requires Docker socket access.

SANDBOX_ENABLED=false
SANDBOX_DOCKER_HOST=unix:///var/run/docker.sock
# SANDBOX_PULL_IMAGES=true

# =============================================================================
# SCIM RATE LIMITING (Optional)
# =============================================================================
# Rate limiting for SCIM 2.0 provisioning endpoints (Okta, Azure AD, etc.)

# SCIM_RATE_LIMIT_ENABLED=true
# SCIM_RATE_LIMIT_PER_MINUTE=60

# =============================================================================
# LOGGING (Optional)
# =============================================================================
# Granular log level control for debugging and performance.

# LOG_LEVEL_APP=INFO
# LOG_LEVEL_SECURITY=WARN
# LOG_LEVEL_WEB=WARN
# LOG_LEVEL_SQL=WARN

# Axiom cloud log shipping (optional - no-ops when not configured)
# AXIOM_TOKEN=
# AXIOM_DATASET=nodeloom-production

# =============================================================================
# MEMORY LIMITS (Optional)
# =============================================================================
# Override container memory limits if needed.

# BACKEND_MEMORY_LIMIT=4G
# FRONTEND_MEMORY_LIMIT=512M
# POSTGRES_MEMORY_LIMIT=4G
# REDIS_MEMORY_LIMIT=1G

# =============================================================================
# SPRING PROFILE
# =============================================================================

SPRING_PROFILES_ACTIVE=production
