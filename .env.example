# NodeLoom Self-Hosted Configuration
# Copy this file to .env and fill in the required values

# =============================================================================
# REQUIRED SETTINGS
# =============================================================================

# Database password (generate a strong random password)
POSTGRES_PASSWORD=your_secure_postgres_password_here

# Redis password (generate a strong random password)
REDIS_PASSWORD=your_secure_redis_password_here

# JWT Secret (generate with: openssl rand -base64 64)
JWT_SECRET=your_256_bit_jwt_secret_here

# =============================================================================
# VERSION
# =============================================================================

# NodeLoom version to deploy (default: latest)
AGENTHERO_VERSION=latest

# =============================================================================
# DATABASE SETTINGS
# =============================================================================

POSTGRES_DB=nodeloom
POSTGRES_USER=nodeloom
POSTGRES_PORT=5432

# =============================================================================
# REDIS SETTINGS
# =============================================================================

REDIS_PORT=6379

# =============================================================================
# APPLICATION PORTS
# =============================================================================

BACKEND_PORT=8080
FRONTEND_PORT=3000

# Public URL for the API (used by frontend)
# Change this to your actual domain in production
PUBLIC_API_URL=http://localhost:8080

# =============================================================================
# AI PROVIDERS (Optional - add as needed)
# =============================================================================

# OpenAI
OPENAI_API_KEY=

# Anthropic (Claude)
ANTHROPIC_API_KEY=

# Google AI (Gemini)
GOOGLE_AI_API_KEY=

# Azure OpenAI
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=

# =============================================================================
# OAUTH PROVIDERS (Optional)
# =============================================================================

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Slack OAuth
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# =============================================================================
# STRIPE (Optional - for billing)
# =============================================================================

STRIPE_ENABLED=false
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# =============================================================================
# SANDBOX EXECUTION (Optional)
# =============================================================================

# Enable sandboxed code execution in Docker containers
SANDBOX_ENABLED=false
SANDBOX_DOCKER_HOST=unix:///var/run/docker.sock

# =============================================================================
# SPRING PROFILE
# =============================================================================

SPRING_PROFILES_ACTIVE=production
